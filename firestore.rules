rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // Role Helpers
    function isSignedIn() { return request.auth != null; }
    function isTeacher() { 
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher';
    }

    // Specific rules to ensure teacher control where needed, but permissive for now
    match /classes/{id} { allow write: if isTeacher(); }
    match /assignments/{id} { allow write: if isTeacher(); }
    match /categories/{id} { allow write: if isTeacher(); }
    match /tests/{id} { allow write: if isTeacher(); }
    match /revisionItems/{id} { allow write: if isTeacher(); }
    match /schoolEvents/{id} { allow write: if isTeacher(); }
  }
}
